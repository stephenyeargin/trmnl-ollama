<div class="layout layout--row">
  <div class="richtext gap--large lg:gap--xlarge">
    <div class="content gap--medium lg:gap--large" data-content-limiter="true">
    {{ show_message_if_error }}
    {% if show_prompt == "true" %}
      <span class="title title--small lg:title--base">{{ prompt }}</span>
      <div class="divider"></div>
    {% endif %}
    {{ response | markdown_to_html }}
    </div>
  </div>
</div>

<div class="title_bar">
  <img class="image image-stroke image-stroke--xlarge" src="data:image/svg+xml;base64,{{ logo_svg | base64_encode }}" />
  <span class="title">{{ trmnl.plugin_settings.instance_name }}</span>
  <span class="instance"></span>
</div>
